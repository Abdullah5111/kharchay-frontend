# Copy to .env. EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.
# Production / device against the live API:
EXPO_PUBLIC_API_URL=https://kharchayapi.14labs.co/api
# Android emulator + local backend: http://10.0.2.2:8020/api
# Physical device via SSH tunnel + `adb reverse tcp:8020 tcp:8020`: http://127.0.0.1:8020/api
